generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ========== Админ ==========
model Admin {
  id           Int      @id @default(autoincrement())
  login        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ========== Глобальные настройки (singleton) ==========
model Settings {
  id             Int      @id @default(1)
  companyName    String   @default("Сакура")
  mainPhone      String   @default("")
  email          String   @default("")
  vk             String   @default("")
  instagram      String   @default("")
  telegramChatId String   @default("")
  smsEnabled     Boolean  @default(false)
  updatedAt      DateTime @updatedAt
}

// ========== Филиал ==========
model Branch {
  id           Int             @id @default(autoincrement())
  slug         String          @unique
  name         String
  address      String
  phone        String
  description  String?
  latitude     Float
  longitude    Float
  coverImage   String?
  tourUrl      String?
  workingHours Json?
  isActive     Boolean         @default(true)
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  categories   SaunaCategory[]
  saunas       Sauna[]
  bookings     Booking[]
  reviews      Review[]
}

// ========== Категория саун (например "Семейная" / "Обычная" в 9-м комплексе) ==========
model SaunaCategory {
  id        Int      @id @default(autoincrement())
  slug      String                                // "family", "regular"
  name      String                                // "Семейная сауна"
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  saunas    Sauna[]
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, slug])
  @@index([branchId])
}

// ========== Сауна ==========
model Sauna {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  name            String
  type            String                              // "russian" | "finnish" | "hamam"
  typeLabel       String?                             // "Финская сауна"
  size            String?                             // "small" | "large"
  sizeLabel       String?                             // "Малый зал" | "Большой зал"
  description     String?
  capacity        Int      @default(0)
  area            Float?
  poolSize        String?                             // "3×4 м" — null если нет бассейна
  hasBBQ          Boolean  @default(false)
  mainImage       String?                             // URL обложки
  images          Json?                               // string[] — URL'ы фото
  amenities       Json?                               // string[] — основные удобства
  extras          Json?                               // string[] — доп. удобства
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  // Настройки бронирования
  cleaningMinutes Int      @default(60)
  minHours        Int      @default(1)
  openHour        Int      @default(0)
  closeHour       Int      @default(24)
  depositPercent  Int      @default(30)               // % предоплаты от totalPrice

  branchId        Int
  branch          Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  categoryId      Int?
  category        SaunaCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  prices          PriceSlot[]
  bookings        Booking[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([branchId])
  @@index([categoryId])
}

// ========== Цена за час по слотам ==========
model PriceSlot {
  id           Int    @id @default(autoincrement())
  saunaId      Int
  sauna        Sauna  @relation(fields: [saunaId], references: [id], onDelete: Cascade)
  dayType      String                                // "weekday" | "weekend"
  timeSlot     String                                // "day" | "evening" | "night"
  pricePerHour Int
  minHours     Int    @default(2)

  @@unique([saunaId, dayType, timeSlot])
  @@index([saunaId])
}

// ========== Акция ==========
model Promotion {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  title       String
  description String
  note        String?                                 // дополнительная подпись
  icon        String?                                 // имя иконки lucide ("flame", "gift", "cake")
  image       String?
  promoCode   String?
  discount    Int?
  startDate   DateTime?                               // опционально для бессрочных
  endDate     DateTime?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ========== Бронирование ==========
model Booking {
  id            Int      @id @default(autoincrement())
  clientName    String
  phone         String
  startAt       DateTime
  endAt         DateTime
  guests        Int      @default(2)
  comment       String?
  status        String   @default("pending_payment") // "pending_payment" | "new" | "confirmed" | "cancelled" | "completed"
  totalPrice    Int?
  smsSent       Boolean  @default(false)

  // Оплата
  paymentStatus String   @default("pending")          // "pending" | "deposit_paid" | "fully_paid" | "refunded"
  paidAmount    Int      @default(0)                  // в рублях

  branchId      Int
  branch        Branch   @relation(fields: [branchId], references: [id])
  saunaId       Int
  sauna         Sauna    @relation(fields: [saunaId], references: [id])

  payments      Payment[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([saunaId, startAt])
  @@index([branchId, startAt])
  @@index([status])
}

// ========== Платёж ==========
model Payment {
  id              Int       @id @default(autoincrement())
  bookingId       Int
  booking         Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider        String    @default("mock")          // "mock" | "yookassa"
  externalId      String?   @unique                   // ID платежа у провайдера
  amount          Int                                  // в рублях
  currency        String    @default("RUB")
  status          String    @default("pending")       // "pending" | "succeeded" | "canceled"
  type            String                               // "deposit" | "full"
  paymentMethod   String?                              // "card" | "sbp" | ...
  confirmationUrl String?                              // куда редиректить юзера
  paidAt          DateTime?
  refundedAt      DateTime?
  refundedAmount  Int?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([bookingId])
  @@index([status])
  @@index([externalId])
}

// ========== Отзыв ==========
model Review {
  id         Int      @id @default(autoincrement())
  authorName String
  text       String
  rating     Int
  source     String   @default("site")               // "site" | "2gis" | "yandex"
  sourceId   String?  @unique
  branchId   Int?
  branch     Branch?  @relation(fields: [branchId], references: [id])
  isApproved Boolean  @default(false)
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([branchId])
  @@index([isApproved, isVisible])
}
